{
  "manifest_version": 2,
  "name": "navego",
  "version": "1.0",
  "description": "Bloqueador de anúncios.",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": "Images/1.png"
  },
  "icons": {
    "48": "Images/1_2.png",
    "128": "Images/1.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "@navego",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      },
      "strict_min_version": "142.0"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  }
}